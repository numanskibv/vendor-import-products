msgid "Missing filename. Please upload the file again so the filename is sent to Odoo."
msgstr "Bestandsnaam ontbreekt. Upload het bestand opnieuw zodat de bestandsnaam naar Odoo wordt meegestuurd."

#. module: vendor_import_module
#: code:addons/vendor_import_module/wizards/vendor_import_wizard.py:0
msgid "The selected supplier is missing a Reference (Internal Reference).\n\nWhy this matters: this import validates that the uploaded file belongs to the selected supplier by checking the filename prefix.\n\nFix: open the supplier '%(supplier)s' and set its Reference to e.g. 'TGH', then retry the import."
msgstr "De geselecteerde leverancier mist een Referentie (Interne referentie).\n\nWaarom dit belangrijk is: deze import controleert of het geüploade bestand bij de gekozen leverancier hoort door te kijken naar de prefix van de bestandsnaam.\n\nOplossing: open de leverancier '%(supplier)s' en zet de Referentie bijvoorbeeld op 'TGH', en probeer daarna opnieuw te importeren."

#. module: vendor_import_module
#: code:addons/vendor_import_module/wizards/vendor_import_wizard.py:0
msgid "Wrong file for the selected supplier.\n\nExpected: filename must start with supplier Reference '%(prefix)s' (uppercase).\nExample: '%(prefix)s producten ....xlsx'\n\nSelected supplier: %(supplier)s\nSupplier Reference: %(prefix)s\nSelected file: %(filename)s\n\nFix: either select the correct supplier in the wizard, or rename the file so it starts with '%(prefix)s'."
msgstr "Verkeerd bestand voor de geselecteerde leverancier.\n\nVerwacht: de bestandsnaam moet beginnen met de leveranciersreferentie '%(prefix)s' (hoofdletters).\nVoorbeeld: '%(prefix)s producten ....xlsx'\n\nGeselecteerde leverancier: %(supplier)s\nLeveranciersreferentie: %(prefix)s\nGeselecteerd bestand: %(filename)s\n\nOplossing: selecteer de juiste leverancier in de wizard, of hernoem het bestand zodat het begint met '%(prefix)s'."

#. module: vendor_import_module
#: code:addons/vendor_import_module/wizards/vendor_import_wizard.py:0
msgid "The uploaded Excel file is empty."
msgstr "Het geüploade Excel-bestand is leeg."

#. module: vendor_import_module
#: code:addons/vendor_import_module/wizards/vendor_import_wizard.py:0
msgid "Could not read the uploaded Excel file."
msgstr "Kon het geüploade Excel-bestand niet lezen."
