<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_attribute_normalization_wizard_form" model="ir.ui.view">
        <field name="name">attribute.normalization.wizard.form</field>
        <field name="model">attribute.normalization.wizard</field>
        <field name="arch" type="xml">
            <form string="Attribute Normalization">
                <group>
                    <field name="name"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_attribute_normalization_wizard" model="ir.actions.act_window">
        <field name="name">Attribute Normalization</field>
        <field name="res_model">attribute.normalization.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_attribute_normalization_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
