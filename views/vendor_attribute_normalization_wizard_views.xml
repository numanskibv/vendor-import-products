<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vendor_attribute_normalization_wizard_form" model="ir.ui.view">
        <field name="name">vendor.attribute.normalization.wizard.form</field>
        <field name="model">vendor.attribute.normalization.wizard</field>
        <field name="arch" type="xml">
            <form string="Normalisatie van attributen">
                <sheet>
                    <field name="vendor_id" invisible="1"/>
                    <group>
                        <field name="file" filename="filename" widget="binary"/>
                        <field name="filename" invisible="1" force_save="1"/>
                        <field name="attribute_type"/>
                        <button name="action_extract_values" string="Extract values" type="object" class="oe_highlight"/>
                    </group>
                    <group>
                        <field name="raw_values" readonly="1"/>
                    </group>
                    <group>
                        <field name="mapping_ids"/>
                        <button name="action_apply_mapping" string="Apply mapping" type="object" class="oe_highlight"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vendor_attribute_normalization_wizard" model="ir.actions.act_window">
        <field name="name">Normalisatie van attributen</field>
        <field name="res_model">vendor.attribute.normalization.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
