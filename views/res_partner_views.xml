<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_vendor_import_manual" model="ir.ui.view">
        <field name="name">res.partner.form.vendor.import.manual</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Vendor Import">
                    <group>
                        <field name="vendor_import_excel_manual_html" nolabel="1" placeholder="Plaats hier de handleiding voor de Excel kolomnamen van deze leverancier..."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
